{
  "id": "scp-file-explorer",
  "name": "SCP File Explorer",
  "version": "1.0.0",
  "description": "SCP/SFTP file explorer plugin",
  "category": "FILE_EXPLORER",
  "profileType": "SCP_FILE_EXPLORER",
  "defaultPort": 22,
  "icon": "folder",
  "enabled": true,
  "secretTypes": ["LOGIN_PASSWORD", "PASSWORD_ONLY", "SSH_KEY"],
  "supportedAuthTypes": ["login", "secret"],
  "backend": "./backend/index.js",
  "frontend": {
    "entry": "./frontend/scp.plugin.ts"
  },
  "ipc": {
    "send": [],
    "invoke": ["session.fe.scp.register"],
    "on": []
  }
}
