{
  "id": "spice-remote-desktop",
  "name": "SPICE Remote Desktop",
  "version": "1.0.0",
  "description": "SPICE remote desktop client for KVM/QEMU virtual machines",
  "category": "REMOTE_DESKTOP",
  "profileType": "SPICE_REMOTE_DESKTOP",
  "defaultPort": 5900,
  "icon": "desktop_windows",
  "enabled": true,
  "secretTypes": ["PASSWORD_ONLY"],
  "supportedAuthTypes": ["login", "secret"],
  "backend": "./backend/index.js",
  "frontend": {
    "entry": "./frontend/index.js",
    "profileFormElement": "spice-profile-form",
    "sessionElement": "spice-session"
  },
  "ipc": {
    "send": ["session.disconnect.rd.spice"],
    "invoke": ["session.open.rd.spice"],
    "on": ["session.connect.rd.spice", "session.disconnect.rd.spice", "error"]
  }
}
