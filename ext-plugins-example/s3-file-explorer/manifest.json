{
  "id": "s3-file-explorer",
  "name": "S3 File Explorer",
  "version": "1.0.0",
  "description": "Amazon S3 / S3-compatible storage browser (MinIO, Cloudflare R2, etc.)",
  "category": "FILE_EXPLORER",
  "profileType": "S3_FILE_EXPLORER",
  "icon": "cloud",
  "enabled": true,
  "secretTypes": ["LOGIN_PASSWORD"],
  "supportedAuthTypes": ["login", "secret"],
  "backend": "./backend/index.js",
  "frontend": {
    "entry": "./frontend/index.js",
    "profileFormElement": "s3-profile-form"
  },
  "ipc": {
    "send": [],
    "invoke": ["session.fe.s3.register"],
    "on": []
  }
}
