{
  "version": 1,
  "plugins": {
    "ssh-terminal": {
      "name": "SSH Terminal (External)",
      "version": "1.0.0",
      "category": "TERMINAL",
      "profileType": "SSH_TERMINAL",
      "source": "external",
      "ipcChannels": {
        "send": [
          "session.open.terminal.ssh",
          "session.close.terminal.ssh"
        ],
        "invoke": [],
        "on": [
          "session.disconnect.terminal.ssh"
        ]
      }
    }
  },
  "ipc": {
    "send": [
      "session.open.terminal.telnet",
      "session.close.terminal.telnet",
      "session.open.terminal.ssh",
      "session.close.terminal.ssh"
    ],
    "invoke": [],
    "on": [
      "session.disconnect.terminal.ssh"
    ]
  }
}
