{
  "name": "yet-another-electron-term",
  "version": "4.0.2",
  "author": {
    "name": "invince",
    "email": "invincezero@gmail.com"
  },
  "description": "Yet Another Electron Terminal",
  "main": "src-electron/electronMain.js",
  "scripts": {
    "ng": "ng",
    "clean": "rimraf dist",
    "build": "npm run clean && patch-package && ng build --base-href ./ && electron-builder",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start": "concurrently \"npm run ng:serve\" \"npm run electron:dev\"",
    "ng:serve": "ng serve",
    "electron:dev": "wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .",
    "postinstall": "patch-package",
    "rebuild-native": "electron-builder install-app-deps",
    "build:release-win-local": "npm run clean && patch-package && ng build --base-href ./ && electron-builder --windows --publish always"
  },
  "build": {
    "appId": "io.github.invince",
    "productName": "YetAnotherElectronTerm",
    "publish": {
      "provider": "github",
      "owner": "invince",
      "repo": "YAET-RELEASE"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallerIcon": "src-electron/assets/icons/uninstall-icon.ico",
      "warningsAsErrors": false,
      "include": "src-electron/custom-uninstall.nsh"
    },
    "files": [
      "dist/",
      "src-electron/",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src-electron/assets/icons/app-icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "src-electron/assets/icons/app-icon.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "src-electron/assets/icons/app-icon.icns",
      "category": "public.app-category.utilities"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~20.3.21",
    "@angular/cdk": "~20.2.14",
    "@angular/common": "~20.3.21",
    "@angular/compiler": "~20.3.21",
    "@angular/core": "~20.3.21",
    "@angular/forms": "~20.3.21",
    "@angular/material": "~20.2.14",
    "@angular/platform-browser": "~20.3.21",
    "@angular/platform-browser-dynamic": "~20.3.21",
    "@angular/router": "~20.3.21",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@novnc/novnc": "^1.5.0",
    "@types/lodash": "^4.17.13",
    "@types/novnc__novnc": "^1.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "basic-ftp": "^5.3.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.4.3",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "express": "^4.22.1",
    "find-free-ports": "^3.1.1",
    "https-proxy-agent": "^7.0.6",
    "keytar": "^7.9.0",
    "lodash": "^4.17.23",
    "marked": "^17.0.3",
    "material-design-icons-iconfont": "^6.7.0",
    "multer": "^2.1.1",
    "ngx-spinner": "^17.0.0",
    "node-fstab": "^1.0.16",
    "node-powershell": "^5.0.1",
    "node-pty": "^1.1.0",
    "patch-package": "^8.0.0",
    "rxjs": "~7.8.0",
    "simple-git": "^3.36.0",
    "socks-proxy-agent": "^8.0.5",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^11.0.0",
    "telnet-client": "^2.2.2",
    "tslib": "^2.3.0",
    "uuid": "^11.0.3",
    "v9u-smb2": "^1.0.6",
    "ws": "^8.18.0",
    "yazl": "^3.3.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.3.25",
    "@angular/cli": "~20.3.25",
    "@angular/compiler-cli": "~20.3.21",
    "@types/crypto-js": "^4.2.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.7.0",
    "concurrently": "^9.1.1",
    "cross-env": "^7.0.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.11",
    "electron-packager": "^17.1.2",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "wait-on": "^8.0.1"
  }
}
